    "_postman_id": "eae84844-d686-4000-ad49-a57b27fb62c8",
    "name": "Usercentrics Web CMP V3 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Browser-side JavaScript surface of the Usercentrics Web CMP V3 modeled as logical HTTP\noperations. Covers the UC_UI control API, IAB TCF 2.3 __tcfapi, IAB GPP __gpp, and Google\nConsent Mode v2 signals delivered through the Usercentrics CDN script.\n\nReference: https://docs.usercentrics.com/cmp_v3/latest/\n\n\nContact Support:\n Name: Usercentrics Documentation",
      "type": "text/plain"
    }
  }
